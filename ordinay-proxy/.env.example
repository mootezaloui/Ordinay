# Required
JWT_SECRET=your-jwt-signing-secret-here
LLM_API_KEY=your-llm-api-key-here

# Optional — primary backend (defaults shown)
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=gpt-oss:120b-cloud

# Optional — fast backend (simple requests: short context, no tools)
# Leave blank to route everything through primary.
LLM_FAST_BASE_URL=
LLM_FAST_API_KEY=
LLM_FAST_MODEL=

# Optional — capable backend (complex requests: long context, tool calls)
# Leave blank to route everything through primary.
LLM_CAPABLE_BASE_URL=
LLM_CAPABLE_API_KEY=
LLM_CAPABLE_MODEL=

# Optional — routing thresholds
ROUTE_COMPLEX_MSG_THRESHOLD=10
ROUTE_COMPLEX_TOOL_THRESHOLD=1

# Optional — quotas and rate limiting
QUOTA_MONTHLY=500000
QUOTA_YEARLY=1000000
QUOTA_PERPETUAL=2000000
RATE_LIMIT_MAX_REQUESTS=20

# Optional — admin
ADMIN_API_KEY=your-admin-key-for-analytics
