{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "entityType": {
      "type": "string",
      "enum": ["client", "dossier", "lawsuit", "task", "mission", "session", "document"]
    },
    "entityId": {
      "type": "integer",
      "minimum": 1
    },
    "depth": {
      "type": "integer",
      "minimum": 1,
      "default": 1
    },
    "direction": {
      "type": "string",
      "enum": ["up", "down", "both"],
      "default": "both"
    },
    "include": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["dossiers", "lawsuits", "tasks", "missions", "sessions", "documents"]
      },
      "uniqueItems": true
    },
    "accessFilter": {
      "type": "object",
      "properties": {
        "dossiers": { "type": "boolean" },
        "lawsuits": { "type": "boolean" },
        "tasks": { "type": "boolean" },
        "missions": { "type": "boolean" },
        "sessions": { "type": "boolean" },
        "documents": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "required": ["entityType", "entityId"],
  "additionalProperties": false
}
