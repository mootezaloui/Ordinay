# ===========================================
# Ordinay Backend Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3000
NODE_ENV=development
API_PREFIX=/api

# Security
# Required in production to encrypt provider keys/tokens at rest.
APP_SECRET=
# Required when AGENT_DEPLOYMENT_ALLOW_PUBLIC_BIND=true (or whenever token auth is desired).
BACKEND_API_TOKEN=
# Optional comma-separated allowlist for browser origins.
# Example: CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# Sensitive endpoint rate limits (/settings, /documents, /email, /imports)
SENSITIVE_RATE_LIMIT_ENABLED=true
SENSITIVE_RATE_LIMIT_REQUESTS=30
SENSITIVE_RATE_LIMIT_WINDOW_MS=60000

# ===========================================
# Email Configuration (Client Notifications)
# ===========================================
# Set EMAIL_ENABLED=true to enable email sending
# If false or not set, emails will be logged but not sent

EMAIL_ENABLED=false

# SMTP Server Settings
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-password

# Sender Information (shown in emails)
EMAIL_FROM_NAME=Your Law Firm
EMAIL_FROM_ADDRESS=noreply@example.com

# ===========================================
# MCP External Search (SEARCH_WEB lane)
# ===========================================
# Backend MCP client settings (used by local mock search tooling)
MCP_WEBSEARCH_SERVER_NAME=websearch
MCP_WEBSEARCH_TRANSPORT=http
MCP_WEBSEARCH_ENDPOINT=http://localhost:3100
MCP_TIMEOUT=15000

# Optional: local mock MCP websearch server settings
MCP_WEBSEARCH_PORT=3100

# ===========================================
# LangSearch Provider (simple web search only)
# ===========================================
LANGSEARCH_API_KEY=
LANGSEARCH_BASE_URL=https://api.langsearch.com
LANGSEARCH_TIMEOUT=15000

# ===========================================
# Groq Fallback (free tier, used when Ollama is unavailable)
# ===========================================
GROQ_API_KEY=
# GROQ_BASE_URL=https://api.groq.com/openai

# ===========================================
# Ollama Streaming
# ===========================================
OLLAMA_STREAMING=true
OLLAMA_STREAM_CHUNK_SIZE=1
LLM_WEB_SEARCH_SUMMARY_TIMEOUT=15000
LLM_DRAFT_TIMEOUT=60000
LLM_DRAFT_NUM_PREDICT=500

# ===========================================
# Offline Document Intelligence (pdfjs + tesseract.js)
# ===========================================
# Cloud OCR is disabled in offline mode.
DOCUMENT_AI_ENABLED=false
DOCUMENT_AI_PROVIDER=local

# OCR behavior
DOCUMENT_OCR_LANG=eng
DOCUMENT_OCR_TIMEOUT_MS=120000
DOCUMENT_OCR_MIN_LENGTH=1

# Hardware-aware document intelligence controls
DOC_INTEL_DEFAULT_LANG=eng
DOC_INTEL_MAX_PAGES_AUTO=5
DOC_INTEL_MAX_PAGES_HARD=25
DOC_INTEL_RENDER_SCALE=2.0
DOC_INTEL_WORKER_TIMEOUT_MS=45000
DOC_INTEL_MEMORY_STOP_THRESHOLD=0.70

# Optional bundled OCR assets root (Electron sets this in production)
# ORDINAY_DOC_INTEL_ASSETS_PATH=...
# DOC_INTEL_TESSDATA_PATH=...\tessdata
# In offline mode keep this false so missing language packs fail fast.
DOC_INTEL_ALLOW_REMOTE_LANG_DOWNLOAD=false

# ===========================================
# Agent v2 Deployment & Runtime Packaging
# ===========================================
# Enable /api/agent/v2/stream rollout endpoint
FEATURE_AGENT_V2_STREAM=false

# Allow non-loopback bind only with explicit opt-in (used for containers)
AGENT_DEPLOYMENT_ALLOW_PUBLIC_BIND=false

# Stream auth (session-scoped token) for /api/agent/v2/stream
# Enabled by default when AGENT_DEPLOYMENT_ALLOW_PUBLIC_BIND=true
AGENT_STREAM_AUTH_REQUIRED=false
AGENT_STREAM_AUTH_SECRET=
AGENT_STREAM_AUTH_TTL_SECONDS=300

# Agent v2 policy normalization (optional overrides)
SESSION_CACHE_MAX=200
RETRIEVAL_CACHE_MAX_SESSIONS=120
RETRIEVAL_CACHE_MAX_DOCS_PER_SESSION=80
SUMMARY_CACHE_MAX=256
CACHE_EVICT_AFTER_TURNS=120
MEMORY_WARNING_HEAP_MB=768

RETRIEVAL_ENABLED=true
RETRIEVAL_TOP_K=6
RETRIEVAL_MAX_CHARS=1400
RETRIEVAL_MIN_SCORE=0.1
RETRIEVAL_MAX_CHUNKS_PER_DOC=2
RETRIEVAL_CHUNK_SIZE=700
RETRIEVAL_CHUNK_OVERLAP=140

RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_MS=60000

SUMMARY_TRIGGER_TURNS=24
SUMMARY_MAX_TOKENS=3500

HEALTH_SNAPSHOT_EVERY_N_TURNS=25
PERFORMANCE_SNAPSHOT_EVERY_N_TURNS=100
